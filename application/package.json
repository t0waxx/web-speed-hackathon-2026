{
  "name": "@web-speed-hackathon-2026/application",
  "private": true,
  "license": "MPL-2.0",
  "author": "CyberAgent, Inc.",
  "type": "module",
  "workspaces": ["client", "server", "e2e"],
  "scripts": {
    "build": "bun run --filter @web-speed-hackathon-2026/client build",
    "start": "bun run --filter @web-speed-hackathon-2026/server start",
    "typecheck": "bun run --workspaces typecheck",
    "format": "bun run format:oxlint && bun run format:oxfmt",
    "format:oxlint": "oxlint --fix",
    "format:oxfmt": "oxfmt"
  },
  "devDependencies": {
    "oxfmt": "0.36.0",
    "oxlint": "1.43.0"
  },
  "engines": {
    "node": "24.14.0"
  },
  "packageManager": "bun@1.3.9",
  "overrides": {
    "gifler>bluebird": "3.7.2",
    "gifler>omggif": "1.0.10"
  },
  "trustedDependencies": [
    "bcrypt",
    "core-js",
    "esbuild",
    "negaposi-analyzer-ja",
    "sqlite3"
  ]
}
